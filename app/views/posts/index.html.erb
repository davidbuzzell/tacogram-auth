<div class="row">
  <% for post in @posts %>
    <div class="col-3">
      <h4>
        <%# 1. find user who created post %>
        <% user = User.find_by({ "id" => post["user_id"] }) %>
        <%# 2. handle any potential bad data where the post is missing a user %>
        <% if user == nil %>
          anonymous
        <% else %>
          <%= user["first_name"] %>
        <% end %>
      </h4>
      <img src="<%= post["image"] %>" class="img-fluid w-full">
      <p><%= post["body"] %></p>
    </div>
  <% end %>
</div>